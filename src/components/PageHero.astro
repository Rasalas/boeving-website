---
interface Props {
  eyebrow: string;
  title: string;
  italic?: string;
  lede?: string;
  num: string;
  image: string;
  imageAlt: string;
}
const { eyebrow, title, italic, lede, num, image, imageAlt } = Astro.props;
---

<section class="relative pt-32 lg:pt-40 pb-12 lg:pb-20 bg-[var(--color-paper)]">
  <div class="container-page">
    <div class="grid grid-cols-12 gap-x-6 gap-y-10">
      <div class="col-span-12 lg:col-span-7 relative">
        <p class="eyebrow flex items-center gap-3">
          <span class="num-marker text-[var(--color-gold-700)]">— {num}</span>
          <span>{eyebrow}</span>
        </p>
        <h1 class="display-1 mt-6 anim-rise">
          {title}
          {italic && <><br/><span class="swash-italic text-[var(--color-gold-700)]">{italic}</span></>}
        </h1>
        {lede && (
          <p class="mt-8 max-w-xl text-lg leading-relaxed text-[var(--color-ink-700)]/85 anim-rise delay-300">
            {lede}
          </p>
        )}
      </div>
      <div class="col-span-12 lg:col-span-5 lg:pl-8 self-end">
        <figure class="relative aspect-[4/5] overflow-hidden rounded-sm anim-fade delay-500 frame-corner">
          <img src={image} alt={imageAlt} class="w-full h-full object-cover" loading="eager" />
          <span class="pointer-events-none absolute inset-0 ring-1 ring-inset ring-[var(--color-ink-900)]/10"></span>
        </figure>
      </div>
    </div>
  </div>

  <!-- Diagonal decorative edge -->
  <div aria-hidden="true" class="absolute inset-x-0 bottom-0 h-24 bg-gradient-to-b from-transparent to-[var(--color-paper-2)]/40"></div>
</section>
