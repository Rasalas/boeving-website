---
import { romanToArabic } from "~/utils/roman";

export interface Props {
  value: string;
  /** Override the resolved Arabic value (rarely needed). */
  arabic?: string;
  /** Element tag — defaults to span. */
  as?: string;
  class?: string;
}

const { value, arabic, as = "span", class: cls = "" } = Astro.props as Props;
const target = arabic ?? romanToArabic(value);
const Tag = as as keyof HTMLElementTagNameMap;
---

<Tag
  class:list={["inline-block", cls]}
  data-decrypt={target}
  data-decrypt-original={value}
>{value}</Tag>
