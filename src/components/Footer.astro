---
import { site, nav } from "~/data/site";
import { asset } from "~/utils/asset";
const year = new Date().getFullYear();
---

<footer class="relative bg-[var(--color-ink-900)] text-[var(--color-paper)] overflow-hidden">
  <!-- Decorative gold field -->
  <div class="absolute inset-x-0 top-0 h-px hairline opacity-60"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -top-40 -right-40 w-[28rem] h-[28rem] rounded-full bg-[var(--color-ink-700)] opacity-50 blur-3xl"></div>
  <div aria-hidden="true" class="pointer-events-none absolute -bottom-32 -left-20 w-[22rem] h-[22rem] rounded-full bg-[var(--color-gold-700)]/15 blur-3xl"></div>

  <!-- Big mark -->
  <div class="container-page relative pt-20 lg:pt-28 pb-12 grid grid-cols-12 gap-x-6 gap-y-12">
    <div class="col-span-12 lg:col-span-7">
      <p class="eyebrow text-[var(--color-gold-300)]">Frankfurter Straße 45 · 58339 Breckerfeld</p>
      <h2 class="display-2 mt-6 text-[var(--color-paper)]">
        Wir freuen uns,<br/>
        <span class="swash-italic text-[var(--color-gold-400)]">wenn Sie kommen.</span>
      </h2>
      <p class="mt-6 max-w-md text-[var(--color-paper)]/70 leading-relaxed">
        In zwei Minuten direkt online buchen — Bestpreis­garantie, sofortige Bestätigung,
        kostenlose Stornierung bis 18&nbsp;Uhr Anreisetag.
      </p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <a
          href={site.booking.directUrl}
          target="_blank"
          rel="noopener"
          class="group inline-flex items-center gap-3 rounded-full bg-[var(--color-gold-500)] px-6 py-3.5 text-[var(--color-ink-900)] hover:bg-[var(--color-gold-400)] transition-colors"
        >
          <span class="font-medium tracking-wide">Direkt buchen</span>
          <span class="num-marker text-[10px] tracking-[0.18em] rounded-full bg-[var(--color-ink-900)]/15 px-2 py-0.5">−{site.booking.directDiscount}&nbsp;€</span>
          <span class="font-display group-hover:translate-x-0.5 transition-transform">→</span>
        </a>
        <a
          href={`mailto:${site.contact.email}`}
          class="inline-flex items-center gap-2 px-3 py-3 text-[var(--color-paper)]/75 hover:text-[var(--color-paper)] transition-colors text-sm"
        >
          <span>oder per Mail: {site.contact.email}</span>
        </a>
      </div>
      <p class="mt-4 text-xs text-[var(--color-paper)]/45">
        Telefon nur als Notfall: <span class="num-marker">{site.contact.phone}</span> · Mo–Sa, 16–20&nbsp;Uhr
      </p>
    </div>

    <div class="col-span-6 lg:col-span-2">
      <p class="eyebrow text-[var(--color-paper)]/50">Seiten</p>
      <ul class="mt-4 space-y-2.5 text-[var(--color-paper)]/85">
        {nav.map((n) => (
          <li><a href={asset(n.href)} class="inline-flex items-baseline gap-2 hover:text-[var(--color-gold-300)] transition-colors">
            <span class="num-marker text-[10px] opacity-50">{n.num}</span>
            {n.label}
          </a></li>
        ))}
      </ul>
    </div>

    <div class="col-span-6 lg:col-span-3">
      <p class="eyebrow text-[var(--color-paper)]/50">Öffnungszeiten</p>
      <dl class="mt-4 space-y-3 text-sm text-[var(--color-paper)]/85">
        <div>
          <dt class="text-[var(--color-paper)]/60">Rezeption</dt>
          <dd class="num-marker mt-0.5">{site.hours.reception}</dd>
        </div>
        <div>
          <dt class="text-[var(--color-paper)]/60">Frühstück</dt>
          <dd class="num-marker mt-0.5">{site.hours.breakfastWeek}</dd>
          <dd class="num-marker">{site.hours.breakfastWeekend}</dd>
          <dd class="text-xs text-[var(--color-paper)]/50 mt-0.5">{site.hours.breakfastClosed}</dd>
        </div>
      </dl>
    </div>
  </div>

  <!-- Giant year wordmark -->
  <div class="relative pointer-events-none select-none overflow-hidden">
    <p
      aria-hidden="true"
      class="display-1 whitespace-nowrap leading-[0.85] text-center text-transparent"
      style="
        font-size: clamp(7rem, 22vw, 22rem);
        background: linear-gradient(180deg,
          color-mix(in srgb, var(--color-gold-500) 35%, transparent) 0%,
          color-mix(in srgb, var(--color-gold-500) 8%, transparent) 50%,
          transparent 100%);
        -webkit-background-clip: text;
        background-clip: text;
        font-variation-settings: 'opsz' 144, 'SOFT' 100, 'WONK' 1;
      "
    >Hotel&nbsp;Böving</p>
  </div>

  <div class="container-page border-t border-[var(--color-paper)]/10 py-6 mt-2 flex flex-col md:flex-row gap-3 justify-between items-start md:items-center text-xs text-[var(--color-paper)]/55">
    <p class="num-marker">© {year} · Hotel Böving garni · seit MDCCCXC</p>
    <ul class="flex gap-5">
      <li><a href={asset("/impressum")} class="hover:text-[var(--color-gold-300)]">Impressum</a></li>
      <li><a href={asset("/datenschutz")} class="hover:text-[var(--color-gold-300)]">Datenschutz</a></li>
      <li><a href={asset("/agb")} class="hover:text-[var(--color-gold-300)]">AGB</a></li>
    </ul>
  </div>
</footer>
