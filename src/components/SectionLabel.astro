---
import RomanDecrypt from "~/components/RomanDecrypt.astro";
interface Props { num: string; title: string; class?: string }
const { num, title, class: cls = "" } = Astro.props;
---
<div class:list={["flex items-center gap-3", cls]}>
  <RomanDecrypt value={num} class="num-marker text-[10px] text-[var(--color-gold-700)] min-w-[1.2em] text-center" />
  <span class="h-px flex-1 bg-[var(--color-ink-700)]/15"></span>
  <span class="eyebrow">{title}</span>
</div>
