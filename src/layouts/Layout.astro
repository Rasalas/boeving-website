---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import TopNotice from "~/components/TopNotice.astro";
import DecryptScript from "~/components/DecryptScript.astro";
import { asset } from "~/utils/asset";

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = "Hotel Böving · garni · Breckerfeld seit 1890",
  description = "Vier-Generationen-Familienhotel im Sauerland. 17 Zimmer, hausgemachtes Frühstück, ehrlicher Empfang.",
  image = "/images/exterior/facade-corner.jpg",
} = Astro.props;

const ogImage = asset(image);
const favicon = asset("/favicon.svg");
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0c1c3d" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="de_DE" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <link rel="canonical" href={Astro.url.href} />
    <title>{title}</title>
  </head>
  <body class="antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-[var(--color-ink-900)] focus:text-[var(--color-paper)] focus:px-3 focus:py-2 focus:rounded-md">Zum Inhalt springen</a>
    <TopNotice />
    <Header />
    <main id="main" class="relative z-10">
      <slot />
    </main>
    <Footer />
    <DecryptScript />
  </body>
</html>
