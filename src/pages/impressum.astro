---
import Layout from "~/layouts/Layout.astro";
import { site } from "~/data/site";
---
<Layout title="Impressum · Hotel Böving">
  <section class="pt-36 lg:pt-44 pb-32 bg-[var(--color-paper)]">
    <div class="container-page max-w-3xl">
      <p class="eyebrow text-[var(--color-gold-700)]">— PFLICHTANGABEN</p>
      <h1 class="display-1 mt-6">Impressum</h1>

      <div class="mt-12 space-y-10 text-[var(--color-ink-700)]/85 leading-relaxed">
        <div>
          <h2 class="font-display text-2xl text-[var(--color-ink-900)]">Anbieter</h2>
          <p class="mt-3">{site.name} garni · Familie Böving<br/>{site.address.street}<br/>{site.address.zip} {site.address.city}<br/>{site.address.country}</p>
        </div>
        <div>
          <h2 class="font-display text-2xl text-[var(--color-ink-900)]">Kontakt</h2>
          <p class="mt-3 num-marker">Tel.: {site.contact.phone}</p>
          <p class="num-marker">Fax: {site.contact.fax}</p>
          <p>E-Mail: <a href={`mailto:${site.contact.email}`} class="underline">{site.contact.email}</a></p>
        </div>
        <div>
          <h2 class="font-display text-2xl text-[var(--color-ink-900)]">Vertretungs­berechtigt & Inhalt</h2>
          <p class="mt-3">Familie Böving — verantwortlich i.S.d. § 18 Abs. 2 MStV.</p>
        </div>
        <div>
          <h2 class="font-display text-2xl text-[var(--color-ink-900)]">Streitschlichtung</h2>
          <p class="mt-3 text-sm">Plattform der EU-Kommission zur Online-Streit­beilegung: <a href="https://ec.europa.eu/consumers/odr/" class="underline" target="_blank" rel="noopener">ec.europa.eu/consumers/odr</a>. Wir nehmen an Streit­schlichtungs­verfahren vor einer Verbraucher­schlichtungs­stelle nicht teil.</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
